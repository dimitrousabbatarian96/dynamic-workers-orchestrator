{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dynamic-workers-orchestrator",
  "main": "src/server.ts",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "worker_loaders": [{ "binding": "LOADER" }],
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "WORKER_FILES",
      "id": "local"
    }
  ]
}
